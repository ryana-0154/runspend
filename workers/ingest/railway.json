{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksConfigPath": "workers/ingest/nixpacks.toml"
  },
  "deploy": {
    "startCommand": "pnpm --filter @runspend/ingest start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
