# Database
DATABASE_URL=postgresql://user:password@localhost:5432/runspend

# Redis (BullMQ + caching)
REDIS_URL=redis://localhost:6379

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Auth.js
AUTH_SECRET=
AUTH_URL=http://localhost:3000
# OAuth credentials for "Sign in with GitHub" — separate from the GitHub App above
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Postgres URL used by the integration test suite (admin DB; tests create
# disposable per-run databases). In CI this points at the postgres service.
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# Resend (transactional email)
RESEND_API_KEY=

# Sentry
SENTRY_DSN=

# Encryption (AES-GCM key for any tokens we persist)
ENCRYPTION_KEY=
